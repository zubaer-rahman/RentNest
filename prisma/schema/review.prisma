model Review {
  id         String   @id @default(uuid())
  propertyId String
  tenantId   String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id])
  tenant   User     @relation(fields: [tenantId], references: [id])

  @@map("reviews")
}
