model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String
  address   String
  role      Role       @default(TENANT)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  properties     Property[]
  rentalRequests RentalRequest[]
  reviews        Review[]

  @@map("users")
}
